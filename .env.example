# Service Desk POC — copy to .env and set values. Never commit .env.
# See tech spec §3.8: same variable names for local (.env) and cluster (Secrets).

# Webhook (Jira Automation sends X-Webhook-Secret header)
WEBHOOK_SECRET=

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/service_desk?sslmode=disable

# Logging: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Optional: worker poll interval in seconds
# WORKER_POLL_INTERVAL_SECONDS=15
