# Service Desk POC — copy to .env and set values. Never commit .env.
# See tech spec §3.8: same variable names for local (.env) and cluster (Secrets).

# Webhook (Jira Automation sends X-Webhook-Secret header)
WEBHOOK_SECRET=

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/service_desk?sslmode=disable

# Logging: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Jira (worker only; Go API does not call Jira)
# Jira Cloud: use base URL e.g. https://your-domain.atlassian.net
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_EMAIL=

# CrewAI / LLM (worker + service-desk-crew; Phase 3+)
OPENAI_API_KEY=
# OPENAI_MODEL_NAME=gpt-4o-mini
# OPENAI_TEMPERATURE=0.2

# Optional: max seconds for one L1 flow run (worker thread pool)
# FLOW_TIMEOUT_SECONDS=900

# Optional: worker poll interval in seconds
# WORKER_POLL_INTERVAL_SECONDS=15

# Phase 4 — kagent MCP (see kagent_setup.md).
# Worker on your Mac: port-forward svc/kagent-controller 8083:8083, then e.g.:
#   http://127.0.0.1:8083/mcp
# Hostnames like *.svc.cluster.local resolve only inside Kubernetes Pods (not in Chrome / on the host).
KAGENT_MCP_URL=
# Optional: Bearer token if your MCP endpoint requires it.
# KAGENT_MCP_TOKEN=
# Default agent ref for diagnostics (override config/mcp_endpoints.yml).
# KAGENT_DIAGNOSTICS_AGENT_REF=kagent/k8s-agent
# Optional: per-call MCP timeout (seconds).
# MCP_TOOL_TIMEOUT_SECONDS=120
# Offline dev: use Phase 3 stub instead of kagent (no KAGENT_MCP_URL needed).
# USE_DIAGNOSTICS_STUB=false